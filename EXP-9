#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>

int main()
{
    key_t key = 1234;
    int shmid;
    char *str;

    // Access shared memory
    shmid = shmget(key, 1024, 0666);

    // Attach shared memory
    str = (char*) shmat(shmid, (void*)0, 0);

    // Read data
    printf("Data read from shared memory: %s\n", str);

    // Detach shared memory
    shmdt(str);

    return 0;
}
