#include <stdio.h>

int main() {
    int pages[] = {7,0,1,2,0,3,0,4,2,3,0,3,2};
    int frames[3], i, j, k, fault = 0;

    for(i=0;i<3;i++) frames[i] = -1;

    for(i=0;i<13;i++) {
        int found = 0;

        for(j=0;j<3;j++)
            if(frames[j] == pages[i])
                found = 1;

        if(!found) {
            int index = -1, farthest = i;

            for(j=0;j<3;j++) {
                int k;
                for(k=i+1;k<13;k++) {
                    if(frames[j] == pages[k])
                        break;
                }

                if(k > farthest) {
                    farthest = k;
                    index = j;
                }
            }

            if(index == -1)
                index = 0;

            frames[index] = pages[i];
            fault++;
        }

        printf("Frames: ");
        for(j=0;j<3;j++)
            printf("%d ", frames[j]);
        printf("\n");
    }

    printf("Page Faults: %d\n", fault);
    return 0;
}
