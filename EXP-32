#include <stdio.h>

int main() {
    int pages[] = {1,2,3,4,1,2,5,1,2,3,4,5};
    int frames[3], time[3];
    int i, j, k, fault = 0, t = 0;

    for(i=0;i<3;i++) frames[i] = -1;

    for(i=0;i<12;i++) {
        int found = 0;

        for(j=0;j<3;j++) {
            if(frames[j] == pages[i]) {
                found = 1;
                time[j] = t++;
            }
        }

        if(!found) {
            int lru = 0;
            for(j=1;j<3;j++)
                if(time[j] < time[lru])
                    lru = j;

            frames[lru] = pages[i];
            time[lru] = t++;
            fault++;
        }

        printf("Frames: ");
        for(k=0;k<3;k++)
            printf("%d ", frames[k]);
        printf("\n");
    }

    printf("Page Faults: %d\n", fault);
    return 0;
}
