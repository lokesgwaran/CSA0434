#include <stdio.h>

struct process {
    int pid;
    int arrival_time;
    int burst_time;
    int remaining_time;
    int completion_time;
    int waiting_time;
    int turnaround_time;
};

int main() {
    int n, time = 0, tq, completed = 0;
    struct process p[10];
    int visited[10] = {0};

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        p[i].pid = i + 1;
        printf("\nEnter Arrival Time and Burst Time for Process %d: ", p[i].pid);
        scanf("%d %d", &p[i].arrival_time, &p[i].burst_time);
        p[i].remaining_time = p[i].burst_time;
    }

    printf("\nEnter Time Quantum: ");
    scanf("%d", &tq);

    while (completed != n) {
        int executed = 0;

        for (int i = 0; i < n; i++) {
            if (p[i].arrival_time <= time && p[i].remaining_time > 0) {
                executed = 1;

                if (p[i].remaining_time > tq) {
                    time += tq;
                    p[i].remaining_time -= tq;
                } else {
                    time += p[i].remaining_time;
                    p[i].remaining_time = 0;
                    completed++;
                    p[i].completion_time = time;
                }
            }
        }

        if (!executed)
            time++; // CPU idle
    }

    for (int i = 0; i < n; i++) {
        p[i].turnaround_time =
            p[i].completion_time - p[i].arrival_time;
        p[i].waiting_time =
            p[i].turnaround_time - p[i].burst_time;
    }

    printf("\nPID\tAT\tBT\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].pid,
               p[i].arrival_time,
               p[i].burst_time,
               p[i].completion_time,
               p[i].waiting_time,
               p[i].turnaround_time);
    }

    return 0;
}
