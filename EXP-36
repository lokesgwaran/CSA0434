#include <stdio.h>

struct node {
    int block;
    struct node *next;
};

int main() {
    int n, i;
    struct node *head = NULL, *temp, *prev = NULL;

    printf("Enter number of blocks: ");
    scanf("%d", &n);

    for(i=0;i<n;i++) {
        temp = (struct node*)malloc(sizeof(struct node));
        printf("Enter block number: ");
        scanf("%d", &temp->block);
        temp->next = NULL;

        if(head == NULL)
            head = temp;
        else
            prev->next = temp;

        prev = temp;
    }

    printf("Linked Allocation:\n");
    temp = head;
    while(temp != NULL) {
        printf("%d -> ", temp->block);
        temp = temp->next;
    }
    printf("NULL\n");

    return 0;
}
