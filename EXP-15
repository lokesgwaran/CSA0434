#include <stdio.h>
#include <string.h>

int main() {
    int users, files, i, j;
    char user[20][20];
    char fname[20][20];

    printf("Enter number of users: ");
    scanf("%d",&users);

    for(i=0;i<users;i++){
        printf("\nEnter username: ");
        scanf("%s",user[i]);

        printf("Enter number of files: ");
        scanf("%d",&files);

        for(j=0;j<files;j++){
            printf("Enter file %d: ",j+1);
            scanf("%s",fname[j]);
        }

        printf("\nFiles of user %s:\n",user[i]);
        for(j=0;j<files;j++){
            printf("%s\n",fname[j]);
        }
    }

    return 0;
}
