#include <stdio.h>

int main() {
    int blocks[5]={100,500,200,300,600};
    int process[4]={212,417,112,426};
    int i,j,best;

    for(i=0;i<4;i++){
        best=-1;

        for(j=0;j<5;j++){
            if(blocks[j]>=process[i]){
                if(best==-1 || blocks[j]<blocks[best])
                    best=j;
            }
        }

        if(best!=-1){
            printf("Process %d allocated to block %d\n",i+1,best+1);
            blocks[best]-=process[i];
        }
    }
}
