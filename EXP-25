#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/stat.h>
#include <dirent.h>

int main() {
    int fd;
    char buffer[100];

    // open file
    fd = open("test.txt", O_RDONLY);

    // read file
    read(fd, buffer, sizeof(buffer));
    printf("File content: %s\n", buffer);

    // lseek
    lseek(fd, 0, SEEK_SET);

    // fcntl
    int flags = fcntl(fd, F_GETFL);
    printf("Flags: %d\n", flags);

    // stat
    struct stat st;
    stat("test.txt", &st);
    printf("File size: %ld\n", st.st_size);

    close(fd);

    // opendir & readdir
    DIR *dir = opendir(".");
    struct dirent *d;

    while ((d = readdir(dir)) != NULL) {
        printf("%s\n", d->d_name);
    }

    closedir(dir);
    return 0;
}
