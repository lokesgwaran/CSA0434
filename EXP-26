#include <stdio.h>

int main() {
    FILE *fp;
    char data[100];

    // create & write
    fp = fopen("file.txt", "w");
    fprintf(fp, "Hello OS Lab");
    fclose(fp);

    // read
    fp = fopen("file.txt", "r");
    fgets(data, 100, fp);
    printf("Data: %s\n", data);
    fclose(fp);

    // append
    fp = fopen("file.txt", "a");
    fprintf(fp, "\nAppend line");
    fclose(fp);

    // delete
    remove("file.txt");

    return 0;
}
