#include <stdio.h>
#include <sys/stat.h>

int main() {
    struct stat st;

    stat("file.txt", &st);

    printf("Permissions:\n");

    printf((st.st_mode & S_IRUSR) ? "r" : "-");
    printf((st.st_mode & S_IWUSR) ? "w" : "-");
    printf((st.st_mode & S_IXUSR) ? "x\n" : "-\n");

    printf("User Types:\n");
    printf("1. Owner\n2. Group\n3. Others\n");

    return 0;
}
