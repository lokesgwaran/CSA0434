#include <stdio.h>
#include <limits.h>

struct process {
    int pid;
    int arrival_time;
    int burst_time;
    int completion_time;
    int waiting_time;
    int turnaround_time;
    int is_completed;
};

int main() {
    int n, time = 0, completed = 0;
    struct process p[10];
    int idx, min_burst;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        p[i].pid = i + 1;
        printf("\nEnter Arrival Time and Burst Time for Process %d: ", p[i].pid);
        scanf("%d %d", &p[i].arrival_time, &p[i].burst_time);
        p[i].is_completed = 0;
    }

    while (completed != n) {
        idx = -1;
        min_burst = INT_MAX;

        // Select shortest job among arrived processes
        for (int i = 0; i < n; i++) {
            if (p[i].arrival_time <= time &&
                p[i].is_completed == 0 &&
                p[i].burst_time < min_burst) {
                min_burst = p[i].burst_time;
                idx = i;
            }
        }

        if (idx != -1) {
            time += p[idx].burst_time;
            p[idx].completion_time = time;
            p[idx].turnaround_time =
                p[idx].completion_time - p[idx].arrival_time;
            p[idx].waiting_time =
                p[idx].turnaround_time - p[idx].burst_time;
            p[idx].is_completed = 1;
            completed++;
        } else {
            time++; // CPU idle
        }
    }

    printf("\nPID\tAT\tBT\tCT\tWT\tTAT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].pid,
               p[i].arrival_time,
               p[i].burst_time,
               p[i].completion_time,
               p[i].waiting_time,
               p[i].turnaround_time);
    }

    return 0;
}
